# Token do bot (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=seu_token_aqui

# ID do servidor Discord (clique direito no servidor → Copiar ID)
DISCORD_GUILD_ID=seu_guild_id_aqui

# URL da API do backend (Railway em produção, localhost em dev)
BACKEND_URL=http://localhost:3001
