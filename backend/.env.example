# ==========================================
# StudyHub Backend — Variáveis de Ambiente
# ==========================================

# Porta do servidor
PORT=3001

# MongoDB (MongoDB Atlas gratuito: https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxxxx.mongodb.net/studyhub?retryWrites=true&w=majority

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=seu_token_aqui

# Discord Guild ID (ID do servidor onde o bot opera)
DISCORD_GUILD_ID=seu_guild_id_aqui

# Origem permitida para CORS (URL do frontend em produção)
FRONTEND_URL=https://seu-usuario.github.io
